{
  "schemaVersion": 1,
  "id": "carpet-permissions",
  "version": "${version}",
  "name": "Carpet Permissions",
  "description": "Adds permission checks to Carpet commands using fabric-permissions-api",
  "authors": [
    "whisperlyric"
  ],
  "contact": {
